{
  "info": {
    "name": "SarrthiIAS Portal",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"admin@sarthiias.com\",\"password\":\"password123\"}" },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"refreshToken\":\"\"}" },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "List Students",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/students?page=1&limit=20"
          }
        },
        {
          "name": "Create Student",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\":\"Test Student\",\"email\":\"test@example.com\",\"mobile\":\"9876543210\",\"targetYear\":2026}" },
            "url": "{{baseUrl}}/students"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Assign Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"studentId\":\"\",\"title\":\"Essay Task\",\"description\":\"Write essay\",\"dueDate\":\"2026-07-01T00:00:00.000Z\",\"priority\":\"High\"}" },
            "url": "{{baseUrl}}/tasks"
          }
        }
      ]
    },
    {
      "name": "Evaluations",
      "item": [
        {
          "name": "Pending Submissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/evaluations/pending"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Analytics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/analytics"
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Generate Study Plan",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/ai/study-plan"
          }
        }
      ]
    },
    {
      "name": "Public",
      "item": [
        {
          "name": "Readiness Analyzer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"dailyHours\":6,\"mockTests\":15,\"stage\":\"Intermediate\",\"optionalSubject\":\"Sociology\"}" },
            "url": "{{baseUrl}}/public/readiness"
          }
        }
      ]
    }
  ]
}
